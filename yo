const canvas = document.getElementById('gameCanvas');
const startLink = document.getElementById('startLink');

let scene, camera, renderer;
let player, bullets = [], enemies = [];
let keys = {};
let mouseDown = false;
let lastShotTime = 0;
let gameStarted = false;

const bulletSpeed = 0.6;
const enemySpeed = 0.02;
const fireDelay = 200;

function init() {
  renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  resize();
  window.addEventListener('resize', resize);

  scene = new THREE.Scene();
  scene.background = new THREE.Color(0x000000);

  camera = new THREE.PerspectiveCamera(
    75,
    window.innerWidth / window.innerHeight,
    0.1,
    1000
  );
  camera.position.set(0, 1.5, 5);

  player = new THREE.Object3D();
  player.position.set(0, 1.5, 5);
  scene.add(player);

  const floorGeo = new THREE.PlaneGeometry(100, 100);
  const floorMat = new THREE.MeshPhongMaterial({ color: 0x111111 });
  const floor = new THREE.Mesh(floorGeo, floorMat);
  floor.rotation.x = -Math.PI / 2;
  scene.add(floor);

  const light = new THREE.DirectionalLight(0xffffff, 1);
  light.position.set(5, 10, 7);
  scene.add(light);
  scene.add(new THREE.AmbientLight(0x404040));

  for (let i = 0; i < 10; i++) spawnEnemy();

  window.addEventListener('keydown', e => (keys[e.code] = true));
  window.addEventListener('keyup', e => (keys[e.code] = false));
  window.addEventListener('mousedown', () => (mouseDown = true));
  window.addEventListener('mouseup', () => (mouseDown = false));
  window.addEventListener('mousemove', onMouseMove);

  animate();
}

function resize() {
  const w = window.innerWidth;
  const h = window.innerHeight;
  renderer.setSize(w, h);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
}

function spawnEnemy() {
  const geo = new THREE.BoxGeometry(1, 1, 1);
  const mat = new THREE.MeshPhongMaterial({ color: 0xff0000 });
  const enemy = new THREE.Mesh(geo, mat);

  const angle = Math.random() * Math.PI * 2;
  const radius = 20 + Math.random() * 10;
  enemy.position.set(
    Math.cos(angle) * radius,
    0.5,
    Math.sin(angle) * radius
  );
  enemy.userData.alive = true;
  scene.add(enemy);
  enemies.push(enemy);
}

function onMouseMove(e) {
  if (!gameStarted) return;
  const dx = (e.movementX || 0) * 0.002;
  player.rotation.y -= dx;
}

function handleInput(delta) {
  const speed = 10 * delta;
  const forward = new THREE.Vector3(0, 0, -1).applyEuler(player.rotation);
  const right = new THREE.Vector3(1, 0, 0).applyEuler(player.rotation);

  if (keys['KeyW']) player.position.addScaledVector(forward, speed);
  if (keys['KeyS']) player.position.addScaledVector(forward, -speed);
  if (keys['KeyA']) player.position.addScaledVector(right, -speed);
  if (keys['KeyD']) player.position.addScaledVector(right, speed);

  camera.position.copy(player.position);
  camera.position.y += 0.2;
  camera.rotation.copy(player.rotation);

  if (mouseDown) tryShoot();
}

function tryShoot() {
  const now = performance.now();
  if (now - lastShotTime < fireDelay) return;
  lastShotTime = now;

  const geo = new THREE.SphereGeometry(0.1, 8, 8);
  const mat = new THREE.MeshBasicMaterial({ color: 0x00ffff });
  const bullet = new THREE.Mesh(geo, mat);

  bullet.position.copy(player.position);
  bullet.position.y += 0.1;
  bullet.userData.dir = new THREE.Vector3(0, 0, -1).applyEuler(player.rotation).normalize();

  scene.add(bullet);
  bullets.push(bullet);
}

function updateBullets(delta) {
  for (let i = bullets.length - 1; i >= 0; i--) {
    const b = bullets[i];
    b.position.addScaledVector(b.userData.dir, bulletSpeed / delta);

    if (b.position.length() > 200) {
      scene.remove(b);
      bullets.splice(i, 1);
      continue;
    }

    for (let j = enemies.length - 1; j >= 0; j--) {
      const e = enemies[j];
      if (!e.userData.alive) continue;
      if (b.position.distanceTo(e.position) < 0.8) {
        e.userData.alive = false;
        scene.remove(e);
        enemies.splice(j, 1);
        scene.remove(b);
        bullets.splice(i, 1);
        break;
      }
    }
  }
}

function updateEnemies(delta) {
  enemies.forEach(e => {
    if (!e.userData.alive) return;
    const dir = new THREE.Vector3()
      .subVectors(player.position, e.position)
      .setY(0)
      .normalize();
    e.position.addScaledVector(dir, enemySpeed / delta);
  });
}

let lastTime = performance.now();
function animate() {
  requestAnimationFrame(animate);
  const now = performance.now();
  const delta = (now - lastTime) / 1000;
  lastTime = now;

  if (gameStarted) {
    handleInput(delta);
    updateBullets(delta);
    updateEnemies(delta);
  }

  renderer.render(scene, camera);
}

startLink.addEventListener('click', () => {
  if (!gameStarted) {
    gameStarted = true;
    startLink.textContent = 'Game Running';
    startLink.style.color = '#888';
  }
});

